# ==========================================================================
# SMAA ERP — Variables de entorno
# Copia este archivo como `.env.local` para desarrollo local,
# y carga las mismas variables en Vercel (Project Settings → Environment Variables).
# NUNCA subas el archivo .env.local real al repositorio.
# ==========================================================================

# --- Supabase (OBLIGATORIAS) -------------------------------------------------
# Project Settings → API en tu proyecto de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...tu-anon-key

# --- Sesión / acceso ---------------------------------------------------------
# Cadena larga y aleatoria para firmar las cookies de sesión (JWT/HMAC).
# Genera una con:  openssl rand -base64 48
SESSION_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria

# Secreto para el endpoint /api/setup que crea al primer empleado master.
# Solo se usa UNA VEZ (cuando no hay empleados aún). Genera: openssl rand -hex 32
SETUP_SECRET=

# NOTA: a partir de la versión con empleados, las contraseñas por departamento
# (MASTER_PASS, SYSTEM_PASS, etc.) YA NO SE USAN para el login normal.
# Se conservan por compatibilidad temporal y para los cron jobs.
# El acceso al sistema ahora es por usuario + contraseña personal.
MASTER_PASS=
SYSTEM_PASS=
PURCHASE_PASS=
SALES_PASS=
CONFIG_PASS=
OT_PASS=
# Contraseña para firmar la liberación de primera pieza (Control de Calidad)
QC_PASS=

# --- Cron jobs de Vercel (vercel.json) ---------------------------------------
# Secreto que protege los endpoints /api/cron/*. Debe coincidir con el header
# Authorization: Bearer <CRON_SECRET> que Vercel envía. Genera: openssl rand -hex 32
CRON_SECRET=

# --- IA: clasificación de facturas (Anthropic Claude) ------------------------
# Necesaria para el buzón de facturas / conciliación con IA.
ANTHROPIC_API_KEY=sk-ant-...

# --- Cifrado de tokens de Google (integración Gmail) -------------------------
# Clave AES-256: EXACTAMENTE 32 bytes en hexadecimal (64 caracteres).
# Genera una con:  openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# --- Integración Gmail (sincronización de correo / facturas) -----------------
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL de callback autorizada en Google. En producción apunta a tu dominio:
# https://TU-DOMINIO.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
